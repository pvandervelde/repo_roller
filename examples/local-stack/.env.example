# RepoRoller — local Docker Compose environment
#
# Copy this file to .env and fill in the values before running:
#   cp .env.example .env
#   docker compose up --build
#
# SECURITY: .env contains secrets — never commit it to source control.

# ==============================================================================
# Backend (Rust API)
# ==============================================================================

# GitHub App ID — found on the App settings page under "App ID"
GITHUB_APP_ID=

# GitHub App private key in PEM format (the entire key as one line with \n
# replacing actual newlines).
#
# To convert your downloaded .pem file to a single-line variable:
#   awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;} END { print ""; }' your-app.private-key.pem
#
# The value should look like:
#   GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n
GITHUB_APP_PRIVATE_KEY=

# Name of the metadata repository in your GitHub org that holds RepoRoller
# configuration (global defaults, team configs, etc.).
# Defaults to ".reporoller" when unset.
METADATA_REPOSITORY_NAME=.reporoller

# JWT secret for signing backend-issued tokens.
# Must be at least 32 characters.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Log level for the Rust API. One of: error, warn, info, debug, trace.
RUST_LOG=info

# ==============================================================================
# Frontend (SvelteKit)
# ==============================================================================

# GitHub OAuth App credentials.
# Create an OAuth App at https://github.com/organizations/<org>/settings/applications/new
# or https://github.com/settings/applications/new
#
# Authorization callback URL must be set to: <ORIGIN>/auth/callback
# e.g. for local testing: http://localhost:3000/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub organization slug (the part after github.com/ in your org URL).
# Example: if your org is at https://github.com/acme-corp, use "acme-corp"
GITHUB_ORG=

# Public URL of the frontend. Required by SvelteKit for CSRF protection.
# For local Docker testing this is always http://localhost:3000.
# Must match the OAuth App callback URL base.
ORIGIN=http://localhost:3000

# Session cookie signing secret. Must be at least 32 characters.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Optional branding override shown in the page header.
BRAND_APP_NAME=RepoRoller
