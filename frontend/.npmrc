engine-strict=true
# Require exact versions when adding new deps (no ^ or ~ ranges)
save-exact=true
# Strict peer dependency resolution
strict-peer-dependencies=false
# Use pnpm's content-addressable store for security and deduplication
prefer-frozen-lockfile=true
# Hoist picomatch so vite can resolve it under Node 24's stricter ESM
# boundary checks (vite uses it internally but doesn't list it as a direct dep).
public-hoist-pattern[]=picomatch
