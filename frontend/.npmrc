engine-strict=true
# Require exact versions when adding new deps (no ^ or ~ ranges)
save-exact=true
# Strict peer dependency resolution
strict-peer-dependencies=false
# Use pnpm's content-addressable store for security and deduplication
prefer-frozen-lockfile=true
# vite 6 imports several packages from its internal bundle (esbuild, picomatch,
# fdir, tinyglobby) that it does not declare as direct dependencies. Under Node
# 24's stricter ESM boundary checks pnpm's default strict isolation causes these
# to be invisible to vite at build time. shamefully-hoist restores npm-style
# hoisting so all transitive packages land in root node_modules and are
# resolvable — the standard pnpm recommendation for vite-based projects.
shamefully-hoist=true
