engine-strict=true
# Require exact versions when adding new deps (no ^ or ~ ranges)
save-exact=true
# Strict peer dependency resolution
strict-peer-dependencies=false
# Use pnpm's content-addressable store for security and deduplication
prefer-frozen-lockfile=true
# Hoist packages that vite imports internally but doesn't declare as direct deps.
# Required under Node 24's stricter ESM boundary checks.
public-hoist-pattern[]=picomatch
public-hoist-pattern[]=esbuild
