engine-strict=true
# Require exact versions when adding new deps (no ^ or ~ ranges)
save-exact=true
# Strict peer dependency resolution
strict-peer-dependencies=false
# Use pnpm's content-addressable store for security and deduplication
prefer-frozen-lockfile=true
# vite 6 compiles vite.config.ts into node_modules/.vite-temp/ at build time.
# Under Node 24's stricter ESM boundary enforcement, files inside that directory
# cannot resolve packages from pnpm's virtual symlink store (the default linker),
# causing ERR_MODULE_NOT_FOUND for @sveltejs/kit and other direct dependencies.
#
# node-linker=hoisted makes pnpm use a flat node_modules layout (like npm),
# so all packages are reachable from the project root regardless of where vite
# places its temp files. This is the recommended fix for pnpm + vite + Node 24.
node-linker=hoisted
