# Dependencies — always installed fresh inside the container by pnpm install.
# Never copy host node_modules into the image.
node_modules

# SvelteKit generated files — regenerated by pnpm run build inside the container.
.svelte-kit
build

# Local environment files — must never end up in the image.
.env
.env.*
!.env.example

# Development / tooling artefacts that don't belong in the image.
coverage
playwright-report
test-results
*.log

# OS / editor noise
.DS_Store
Thumbs.db
